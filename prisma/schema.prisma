// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  nickname      String     @unique
  passwordHash  String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  predictions   Prediction[]
  seasonUsers   SeasonUser[]

  @@index([email])
}

model Invitation {
  id            String     @id @default(cuid())
  email         String     @unique
  token         String     @unique
  nickname      String     // Nickname asignado para este usuario
  used          Boolean    @default(false)
  usedAt        DateTime?
  expiresAt     DateTime
  createdAt     DateTime   @default(now())

  @@index([token])
  @@index([email])
}

model Season {
  id            String     @id @default(cuid())
  name          String     // "2025-2026", "2024-2025"
  startDate     DateTime
  endDate       DateTime?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  jornadas      Jornada[]
  seasonUsers   SeasonUser[]
  rankings      RankingResult[]

  @@unique([name])
  @@index([isActive])
}

model SeasonUser {
  id            String     @id @default(cuid())
  seasonId      String
  userId        String
  hasWonPrize   Boolean    @default(false) // ¿Ha cobrado al menos un premio?

  season        Season     @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@index([seasonId])
}

model Jornada {
  id            String     @id @default(cuid())
  seasonId      String
  userId        String     // Usuario que creó la jornada
  weekNumber    Int        // 1-42 aproximadamente
  matchDate     DateTime   // Fecha del partido
  boleto        String?    // JSON string con pronósticos
  totalMatches  Int        @default(14) // Cantidad de partidos en la jornada

  // Premios (ingresados manualmente después de finalizada)
  premio15      Float?     // Premio por 15 aciertos
  premio14      Float?     // Premio por 14 aciertos
  premio13      Float?     // Premio por 13 aciertos
  premio12      Float?     // Premio por 12 aciertos
  premio11      Float?     // Premio por 11 aciertos
  premio10      Float?     // Premio por 10 aciertos

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  season        Season     @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  creator       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  predictions   Prediction[]
  prizes        Prize[]

  @@unique([seasonId, weekNumber])
  @@index([seasonId])
  @@index([userId])
}

model Prediction {
  id            String     @id @default(cuid())
  jornadaId     String
  userId        String
  hits          Int        // Número de aciertos (4-14)
  points        Float      @default(0) // Puntos por aciertos
  rawPoints     Float      @default(0) // Puntos sin activar (antes de cobrar un premio)
  notes         String?    // Notas adicionales
  boletoImageUrl String?   // URL de imagen del boleto
  boletoUploadDate DateTime? // Fecha de subida del boleto
  hasResults    Boolean    @default(false) // ¿Se ingresaron los resultados?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  jornada       Jornada    @relation(fields: [jornadaId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  partidoResults PartidoResult[]

  @@unique([jornadaId, userId])
  @@index([jornadaId])
  @@index([userId])
}

model PartidoResult {
  id                    String     @id @default(cuid())
  predictionId          String
  numero                Int        // 1-14
  equipo1               String     // Team 1
  equipo2               String     // Team 2
  userPrediction        String     // 1, X, o 2
  userPleonoPrediction  Int?       // Predicción de goles (Pleno al Quince)
  actualResult          String?    // 1, X, o 2 (después de partido)
  actualPleonoResult    Int?       // Goles reales
  isCorrect             Boolean    @default(false) // ¿Acertó?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  prediction    Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@index([predictionId])
}

model Prize {
  id            String     @id @default(cuid())
  jornadaId     String
  userId        String?    // null si nadie en el grupo cobró
  hits          Int        // 10, 11, 12, 13, 14
  amount        Float      // Cantidad en euros
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  jornada       Jornada    @relation(fields: [jornadaId], references: [id], onDelete: Cascade)

  @@index([jornadaId])
}

model RankingResult {
  id            String     @id @default(cuid())
  seasonId      String
  userId        String
  totalPrizes   Float      @default(0) // Total en euros ganados
  totalPoints   Float      @default(0) // Total de puntos por aciertos
  validPoints   Float      @default(0) // Puntos válidos (solo si ha cobrado)
  position      Int?       // 1, 2, 3, 4...
  rawPoints     Float      @default(0) // Puntos sin validar
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  season        Season     @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@index([seasonId])
  @@index([position])
}

model EmailLog {
  id            String     @id @default(cuid())
  userId        String?
  email         String
  subject       String
  status        String     // "sent", "failed", "pending"
  error         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([email])
  @@index([createdAt])
}
